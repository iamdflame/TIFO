# TIFO configuration — copy to .env
# Run `npm run activate` to fill the TXLINE_* values automatically via the
# on-chain Solana free-tier subscription.

# mainnet | devnet
TXLINE_NETWORK=mainnet

# Long-lived API token from POST /api/token/activate
TXLINE_API_TOKEN=

# Optional pre-acquired guest JWT (auto-renewed at runtime if omitted/expired)
TXLINE_JWT=

# Optional overrides
# TXLINE_ORIGIN=https://txline.txodds.com
# TXLINE_COMPETITION_ID=72
# PORT=8090
# SOLANA_RPC=
